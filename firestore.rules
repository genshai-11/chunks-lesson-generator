rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidNumber(field) {
      return request.resource.data[field] is number;
    }

    function isValidResource() {
      return hasRequiredFields(['name', 'color', 'ohm', 'userId', 'createdAt']) &&
             isValidString('name', 0, 100) &&
             request.resource.data.color in ['Green', 'Blue', 'Pink', 'Red'] &&
             isValidNumber('ohm');
    }

    function isValidChunk() {
      return hasRequiredFields(['resourcesUsed', 'engSentence', 'vieSentence', 'rTotal', 'iValue', 'uTotal', 'category', 'difficultyLabel', 'userId', 'createdAt']) &&
             request.resource.data.resourcesUsed is list &&
             request.resource.data.resourcesUsed.size() <= 50 &&
             isValidString('engSentence', 0, 2000) &&
             isValidString('vieSentence', 0, 2000) &&
             isValidNumber('rTotal') &&
             isValidNumber('iValue') &&
             isValidNumber('uTotal') &&
             isValidString('category', 0, 100) &&
             isValidString('difficultyLabel', 0, 100);
    }

    function isValidAISettings() {
      return hasRequiredFields(['endpoint', 'apiKey', 'primaryModel', 'fallbackModel']) &&
             isValidString('endpoint', 0, 500) &&
             isValidString('apiKey', 0, 500) &&
             isValidString('primaryModel', 0, 200) &&
             isValidString('fallbackModel', 0, 200) &&
             (!('elevenLabsApiKey' in request.resource.data) || isValidString('elevenLabsApiKey', 0, 500)) &&
             (!('elevenLabsModel' in request.resource.data) || isValidString('elevenLabsModel', 0, 200)) &&
             (!('elevenLabsVoiceId' in request.resource.data) || isValidString('elevenLabsVoiceId', 0, 200));
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /workspaces/{workspaceId} {
      allow read, write: if isAuthenticated();

      match /resources/{resourceId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidResource() && request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated() && isValidResource() && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isAuthenticated();
      }

      match /chunks/{chunkId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidChunk() && request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated() && isValidChunk() && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isAuthenticated();
      }

      match /settings/{settingId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && isValidAISettings();
      }
    }
    
    // Keep legacy user rules for backward compatibility if needed, but we will migrate to workspaces
    match /users/{userId} {
      // User document itself (if needed)
      allow read, write: if isOwner(userId);

      match /resources/{resourceId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidResource();
        allow update: if isOwner(userId) && isValidResource() && request.resource.data.userId == resource.data.userId && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId);
      }

      match /chunks/{chunkId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChunk();
        allow update: if isOwner(userId) && isValidChunk() && request.resource.data.userId == resource.data.userId && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isOwner(userId);
      }

      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidAISettings();
      }
    }
  }
}
