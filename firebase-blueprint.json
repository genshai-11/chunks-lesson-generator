{
  "entities": {
    "Resource": {
      "title": "Resource",
      "description": "A language resource with a base ohm value and color category.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The word or phrase."
        },
        "color": {
          "type": "string",
          "enum": ["Green", "Blue", "Pink", "Red"],
          "description": "The color category representing the type of resource."
        },
        "ohm": {
          "type": "number",
          "description": "The base resistance (R) value."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this resource."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp."
        }
      },
      "required": ["name", "color", "ohm", "userId", "createdAt"]
    },
    "Chunk": {
      "title": "Chunk",
      "description": "A generated bilingual sentence chunk.",
      "type": "object",
      "properties": {
        "resourcesUsed": {
          "type": "array",
          "items": {
            "$ref": "#/entities/Resource"
          },
          "description": "List of resources used in this chunk."
        },
        "engSentence": {
          "type": "string",
          "description": "The generated English sentence."
        },
        "vieSentence": {
          "type": "string",
          "description": "The Vietnamese translation."
        },
        "rTotal": {
          "type": "number",
          "description": "Total resistance calculated from resources."
        },
        "iValue": {
          "type": "number",
          "description": "Current (MSE) value used."
        },
        "uTotal": {
          "type": "number",
          "description": "Total voltage (Difficulty)."
        },
        "category": {
          "type": "string",
          "description": "Thematic category."
        },
        "difficultyLabel": {
          "type": "string",
          "description": "Label for difficulty based on U."
        },
        "audioUrl": {
          "type": "string",
          "description": "URL to the generated audio file (optional)."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this chunk."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp."
        }
      },
      "required": ["resourcesUsed", "engSentence", "vieSentence", "rTotal", "iValue", "uTotal", "category", "difficultyLabel", "userId", "createdAt"]
    },
    "AISettings": {
      "title": "AISettings",
      "description": "User configuration for AI generation (OpenRouter).",
      "type": "object",
      "properties": {
        "endpoint": {
          "type": "string",
          "description": "API endpoint URL."
        },
        "apiKey": {
          "type": "string",
          "description": "API key for the AI service."
        },
        "primaryModel": {
          "type": "string",
          "description": "Primary AI model ID."
        },
        "fallbackModel": {
          "type": "string",
          "description": "Fallback AI model ID."
        },
        "elevenLabsApiKey": {
          "type": "string",
          "description": "API key for ElevenLabs TTS."
        },
        "elevenLabsModel": {
          "type": "string",
          "description": "Model ID for ElevenLabs TTS."
        },
        "elevenLabsVoiceId": {
          "type": "string",
          "description": "Voice ID for ElevenLabs TTS."
        }
      },
      "required": ["endpoint", "apiKey", "primaryModel", "fallbackModel"]
    }
  },
  "firestore": {
    "/users/{userId}/resources/{resourceId}": {
      "schema": {
        "$ref": "#/entities/Resource"
      },
      "description": "Resources owned by a specific user."
    },
    "/users/{userId}/chunks/{chunkId}": {
      "schema": {
        "$ref": "#/entities/Chunk"
      },
      "description": "Chunks generated by a specific user."
    },
    "/users/{userId}/settings/{settingId}": {
      "schema": {
        "$ref": "#/entities/AISettings"
      },
      "description": "User-specific settings (e.g., AI configuration)."
    }
  }
}
